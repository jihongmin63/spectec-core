syntax matchreulres = ctx prem*
dec $match_rule(ctx, id, rulmatch, val*) : matchreulres
def $match_rule(C, id, rulmatch, val*) = C' prem*
    -- if exp* `- prem* = rulmatch
    -- if OK C' = $assign_exps(C, exp*, val*)

dec $invoke_extern_rel(id, val*) : res<val*>

syntax resvals = res<val*>

dec $do_backtrack_rulepath(ctx, id, rulmatch, rulpath, val*) : res<val*>
def $do_backtrack_rulepath(C, id, rulmatch, rulpath, val*) = OK val'*
  -- if id `= exp* `- prem* = rulpath
  -- if ctx_local = C[.LOCAL = {TYP $empty_map<id, typdef>, REL $empty_map<id, reldef>, FUNC $empty_map<id, funcdef>, VAL $empty_map<vari, val>}]
  -- if ctx_new prem_new* = $match_rule(ctx_local, id, rulmatch, val*)
  -- Eval_prems: ctx_new |- (prem* ++ prem_new*) : OK ctx_new'
  -- Eval_exps: ctx_new' |- exp* : OK val'*
def $do_backtrack_rulepath(C, id, rulmatch, rulpath, val*) = FAIL
  -- otherwise

dec $search_resvals(resvals*) : val*?
def $search_resvals(eps) = eps
def $search_resvals(resvals_head :: resvals*) = val*
  -- if OK val* = resvals_head
def $search_resvals(resvals_head :: resvals*) = $search_resvals(resvals*)
  -- if FAIL = resvals_head

dec $fold<X, Y>(X, Y*, def $iter(X, Y) : X) : X
def $fold<X, Y>(X, eps, def $iter) = X 
def $fold<X, Y>(X, Y_head :: Y*, def $iter) = $fold<X, Y>(X', Y*, def $iter)
  -- if X' = $iter(X, Y_head)

syntax transposevalres = val* val**

dec $transposeval_aux(val*, val**, val**) : transposevalres
def $transposeval_aux(val_head*, val_tail**, eps) = val_head* val_tail**
def $transposeval_aux(val_head*, val_tail**, val* :: val_left**) = $transposeval_aux(val_head* ++ [ val_lefthead ], val_tail** ++ [ val_lefttail* ], val_left**)
  -- if val_lefthead :: val_lefttail* = val*

def $transposeval(eps, val_ans**) = val_ans**
def $transposeval(val**, val_ans**) = $transposeval(val_tail**, val_ans** ++ [ val_head* ])
  -- if eps =/= val**
  -- if val_head* val_tail** = $transposeval_aux(eps, eps, val**)