rule Eval_exp/boolean:
  C |- BOOL b : OK (BOOL b)

rule Eval_exp/number:
  C |- num : OK num

rule Eval_exp/string:
  C |- TEXT t : OK (TEXT t)

rule Eval_exp/variable:
  C |- VAR id : OK val
  -- if val = $find_val(C, id eps)

rule Eval_exp/unary_boolean:
  C |- UN NOT (BOOL b) : OK (BOOL (~b))

  rule Eval_exp/and:
    C |- BIN AND (BOOL b_l) (BOOL b_r) : OK (BOOL (b_l /\ b_r))
  
  rule Eval_exp/or:
    C |- BIN OR (BOOL b_l) (BOOL b_r) : OK (BOOL (b_l \/ b_r))
  
  rule Eval_exp/impl:
    C |- BIN IMPL (BOOL b_l) (BOOL b_r) : OK (BOOL (b_l => b_r))
  
  rule Eval_exp/equiv:
    C |- BIN EQUIV (BOOL b_l) (BOOL b_r) : OK (BOOL (b_l <=> b_r))  


rule Eval_exp/binary_number:
  C |- BIN binop num_l num_r : OK $binop_number(binop, num_l, num_r)

  rule Eval_exp/eq:
    C |- CMP EQ exp_l exp_r : OK (BOOL (val_l = val_r))
    -- Eval_exp: C |- exp_l : OK val_l 
    -- Eval_exp: C |- exp_r : OK val_r 
  
  rule Eval_exp/neq:
    C |- CMP NE exp_l exp_r : OK (BOOL (val_l =/= val_r))
    -- Eval_exp: C |- exp_l : OK val_l 
    -- Eval_exp: C |- exp_r : OK val_r 


rule Eval_exp/compare_number:
  C |- CMP cmpop num_l num_r : OK (BOOL $cmpop_number(cmpop, num_l, num_r))

rule Eval_exp/upcast:
  C |- UPCAST typ exp : $upcast(C, typ, val)
  -- Eval_exp: C |- exp : OK val

rule Eval_exp/downcast:
  C |- DOWNCAST typ exp : $downcast(C, typ, val)
  -- Eval_exp: C |- exp : OK val

rule Eval_exp/subtype:
  C |- SUB exp typ : OK (BOOL b)
  -- Eval_exp: C |- exp : OK val
  -- if OK b = $subtyp(C, typ, val)


  rule Eval_exp/inj:
    C |- MATCH exp (INJ mixop_p) : OK (BOOL (mixop_p = mixop_v))
    -- Eval_exp: C |- exp : OK (INJ mixop_v val_v)

  rule Eval_exp/list_cons:
    C |- MATCH exp CONS : OK (BOOL $(|val*| > 0))
    -- Eval_exp: C |- exp : OK (LIST val*)

  rule Eval_exp/list_fixed:
    C |- MATCH exp (FIXED n) : OK (BOOL (|val*| = n))
    -- Eval_exp: C |- exp : OK (LIST val*)

  rule Eval_exp/list_nil:
    C |- MATCH exp NIL : OK (BOOL (|val*| = 0))
    -- Eval_exp: C |- exp : OK (LIST val*)

  rule Eval_exp/opt_some:
    C |- MATCH exp SOME : OK (BOOL true)
    -- Eval_exp: C |- exp : OK (OPT val)

  rule Eval_exp/opt_none:
    C |- MATCH exp NONE : OK (BOOL true)
    -- Eval_exp: C |- exp : OK (OPT eps)
    
  rule Eval_exp/inj_else:
    C |- MATCH exp (INJ mixop_p) : OK (BOOL false)
    -- Eval_exp: C |- exp : OK val
    -- if ~$is_inj(val)

  rule Eval_exp/list_else:
    C |- MATCH exp listpattern : OK (BOOL false)
    -- Eval_exp: C |- exp : OK val
    -- if ~$is_list(val)

  rule Eval_exp/opt_else:
    C |- MATCH exp optpattern : OK (BOOL false)
    -- Eval_exp: C |- exp : OK val
    -- if ~$is_opt(val)


rule Eval_exp/tuple:
  C |- TUP exp* : OK (TUP val*)
  -- Eval_exps: C |- exp* : OK val*

rule Eval_exp/case:
  C |- INJ mixop exp : OK (INJ mixop val)
  -- Eval_exp: C |- exp : OK val

rule Eval_exp/struct:
  C |- STR expfield* : OK (STR valfield*)
  -- (if atom exp = expfield)*
  -- Eval_exps: C |- exp* : OK val*
  -- (if valfield = atom val)*


  rule Eval_exp/some:
    C |- OPT exp : OK (OPT val)
    -- Eval_exp : C |- exp : OK val

  rule Eval_exp/none:
    C |- OPT eps : OK (OPT eps)


rule Eval_exp/list:
  C |- LIST exp* : OK (LIST val*)
  -- Eval_exps: C |- exp* : OK val*

rule Eval_exp/cons:
  C |- CONS exp_h exp_t : OK (LIST (val_h :: val_t*))
  -- Eval_exp: C |- exp_h : OK val_h
  -- Eval_exp: C |- exp_t : OK (LIST val_t*)


  rule Eval_exp/concat_text:
  C |- CAT exp_l exp_r : OK (TEXT (text_l ++ text_r))
  -- Eval_exp: C |- exp_l : OK (TEXT text_l)
  -- Eval_exp: C |- exp_r : OK (TEXT text_r)

  rule Eval_exp/list: 
  C |- CAT exp_l exp_r : OK (LIST (val_l* ++ val_r*))
  -- Eval_exp: C |- exp_l : OK (LIST val_l*)
  -- Eval_exp: C |- exp_r : OK (LIST val_r*)


rule Eval_exp/mem:
  C |- MEM exp_e exp_s : OK (BOOL $exists_((val_e = val)*))
  -- Eval_exp: C |- exp_e : OK val_e
  -- Eval_exp: C |- exp_s : OK (LIST val*)


  rule Eval_exp/len_text:
    C |- LEN exp : OK (NAT (|text|))
    -- Eval_exp: C |- exp : OK (TEXT text)

  rule Eval_exp/list:
    C |- LEN exp : OK (NAT (|val*|))
    -- Eval_exp: C |- exp : OK (LIST val*)


rule Eval_exp/dot:
  C |- DOT exp atom : OK val_res
  -- Eval_exp: C |- exp : OK (STR valfield*)
  -- (if atom_field val_field = valfield)*
  -- if val_res = $find_map<atom, val>(`{ (atom_field `: val_field)* }, atom)


  rule Eval_exp/idx_text:
    C |- IDX exp_b exp_i : OK (TEXT text[n])
    -- Eval_exp: C |- exp_b : OK (TEXT text)
    -- Eval_exp: C |- exp_i : OK (NAT n)

  rule Eval_exp/list:
    C |- IDX exp_b exp_i : OK (val*[n])
    -- Eval_exp: C |- exp_b : OK (LIST val*)
    -- Eval_exp: C |- exp_i : OK (NAT n)

  rule Eval_exp/slice_text:
  C |- SLICE exp_b exp_i exp_n : OK (TEXT text[n_i : n_n])
    -- Eval_exp: C |- exp_b : OK (TEXT text)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)

  rule Eval_exp/list:
    C |- SLICE exp_b exp_i exp_n : OK (LIST val*[n_i : n_n])
    -- Eval_exp: C |- exp_b : OK (LIST val*)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)


rule Eval_exp/upd:
  C |- UPD exp_b path exp_f : $update_path(C, val_b, path, val_f)
  -- Eval_exp: C |- exp_b : OK val_b
  -- Eval_exp: C |- exp_f : OK val_f

rule Eval_exp/call:
  C |- CALL id targ* arg* : valres
  -- Call_func: C |- id targ* arg* : valres


  rule Eval_exp/opt_some:
    C |- ITER exp (QUEST vari) : OK (OPT val)
    -- if C_sub = $sub_opt(C, vari)
    -- Eval_exp: C_sub |- exp : OK val

  rule Eval_exp/opt_none:
    C |- ITER exp (QUEST vari) : OK (OPT eps)
    -- if eps = $sub_opt(C, vari)
    
  rule Eval_exp/list:
    C |- ITER exp (STAR vari*) : OK (LIST val*)
    -- if $sub_list(C, vari*) = C_sub*
    -- (Eval_exp: C_sub |- exp : OK val)*


rule Eval_exp/fail:
  C |- exp : FAIL
  -- otherwise

;;

rule Eval_exps/ok:
  C |- exp* : OK val*
  -- (Eval_exp: C |- exp : OK val)*

rule Eval_exps/fail:
  C |- exp* : FAIL
  -- otherwise

