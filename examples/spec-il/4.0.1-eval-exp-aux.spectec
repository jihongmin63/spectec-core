dec $binop_number(binop, num, num) : val
def $binop_number(ADD, NAT n_l, NAT n_r) = NAT $(n_l + n_r)
def $binop_number(ADD, INT i_l, INT i_r) = INT $(i_l + i_r)
def $binop_number(SUB, NAT n_l, NAT n_r) = NAT n
    -- if n = $(n_l - n_r)
def $binop_number(SUB, INT i_l, INT i_r) = INT $(i_l - i_r)
def $binop_number(MUL, NAT n_l, NAT n_r) = NAT $(n_l * n_r)
def $binop_number(MUL, INT i_l, INT i_r) = INT $(i_l * i_r)
def $binop_number(DIV, NAT n_l, NAT n_r) = NAT $(n_l / n_r)
def $binop_number(DIV, INT i_l, INT i_r) = INT $(i_l / i_r)
def $binop_number(MOD, NAT n_l, NAT n_r) = NAT $(n_l \ n_r)
def $binop_number(MOD, INT i_l, INT i_r) = INT $(i_l \ i_r)
def $binop_number(POW, NAT n_l, NAT n_r) = NAT $(n_l ^ n_r)
def $binop_number(POW, INT i_l, INT i_r) = INT $(i_l ^ i_r)

dec $cmpop_number(cmpop, num, num) : bool
def $cmpop_number(LT, NAT n_l, NAT n_r) = $(n_l < n_r)
def $cmpop_number(LT, INT i_l, INT i_r) = $(i_l < i_r)
def $cmpop_number(GT, NAT n_l, NAT n_r) = $(n_l > n_r)
def $cmpop_number(GT, INT i_l, INT i_r) = $(i_l > i_r)
def $cmpop_number(LE, NAT n_l, NAT n_r) = $(n_l <= n_r)
def $cmpop_number(LE, INT i_l, INT i_r) = $(i_l <= i_r)
def $cmpop_number(GE, NAT n_l, NAT n_r) = $(n_l >= n_r)
def $cmpop_number(GE, INT i_l, INT i_r) = $(i_l >= i_r)

;;

dec $is_tup(val) : bool
def $is_tup(TUP val*) = true
def $is_tup(val) = false
    -- otherwise

dec $is_inj(val) : bool
def $is_inj(INJ mixop val) = true
def $is_inj(val) = false
    -- otherwise

dec $is_list(val) : bool
def $is_list(LIST val*) = true
def $is_list(val) = false
    -- otherwise

dec $is_opt(val) : bool
def $is_opt(OPT val?) = true
def $is_opt(val) = false
    -- otherwise

dec $is_fun(val) : bool
def $is_fun(FUNC id) = true
def $is_fun(val) = false
    -- otherwise

;;

syntax theta = map<id, typ>

dec $subst_typ_inner(theta, typ) : typ
def $subst_typ_inner(theta, NAT) = NAT
def $subst_typ_inner(theta, INT) = INT
def $subst_typ_inner(theta, TEXT) = TEXT
def $subst_typ_inner(theta, BOOL) = BOOL
def $subst_typ_inner(theta, VAR id eps) = typ
    -- if typ = $find_map<id, typ>(theta, id)
def $subst_typ_inner(theta, VAR id targ*) = VAR id $subst_typ_inner(theta, targ)*
    -- if $find_map<id, typ>(theta, id) = eps
def $subst_typ_inner(theta, TUP typ*) = TUP $subst_typ_inner(theta, typ)*
def $subst_typ_inner(theta, ITER typ iter) = ITER $subst_typ_inner(theta, typ) iter
def $subst_typ_inner(theta, FUNC) = FUNC

dec $subst_typ(theta, typ) : typ
def $subst_typ(`{ eps }, typ) = typ
def $subst_typ(theta, typ) = $subst_typ_inner(theta, typ)
    -- otherwise

dec $upcast(ctx, typ, val) : res<val>
def $upcast(C, INT, INT i) = OK (INT i)
def $upcast(C, INT, NAT n) = OK (INT n)
def $upcast(C, INT, val) = FAIL
    -- if ~(val <: num)
def $upcast(C, VAR id targ*, val) = $upcast(C, typ', val)
    -- if (DEF tparam* `-> (ALIAS typ)) = $find_typ(C, id)
    -- if typ' = $subst_typ(`{ (tparam `: targ)* }, typ)
def $upcast(C, TUP typ*, TUP val*) = OK (TUP val_upcast*)
    -- (if OK val_upcast = $upcast(C, typ, val))*
def $upcast(C, TUP typ*, val) = FAIL
    -- if ~$is_tup(val)
def $upcast(C, typ, val) = OK val
    -- otherwise

dec $downcast(ctx, typ, val) : res<val>
def $downcast(C, NAT, NAT n) = OK (NAT n)
def $downcast(C, NAT, INT i) = OK (NAT n)
    -- if n = i
def $downcast(C, NAT, val) = FAIL
    -- if ~(val <: num)
def $downcast(C, VAR id targ*, val) = $downcast(C, typ', val)
    -- if (DEF tparam* `-> (ALIAS typ)) = $find_typ(C, id)
    -- if typ' = $subst_typ(`{ (tparam `: targ)* }, typ)
def $downcast(C, TUP typ*, TUP val*) = OK (TUP val_downcast*)
    -- (if OK val_downcast = $downcast(C, typ, val))*
def $downcast(C, TUP typ*, val) = FAIL
    -- if ~$is_tup(val)
def $downcast(C, typ, val) = OK val
    -- otherwise
;;

dec $subtyp(ctx, typ, val) : res<bool>
dec $subtyps(ctx, typ*, val*) : res<bool>

def $subtyps(C, typ*, val*) = OK ($forall_(b*))
    -- if |typ*| = |val*|
    -- (if OK b = $subtyp(C, typ, val))*
def $subtyps(C, typ*, val*) = OK false
    -- if |typ*| =/= |val*|
def $subtyps(C, typ*, val*) = FAIL
    -- otherwise

def $subtyp(C, BOOL, BOOL b) = OK true
def $subtyp(C, NAT, NAT n) = OK true
def $subtyp(C, NAT, INT i) = OK true
    -- if $(i >= 0)
def $subtyp(C, INT, num) = OK true
def $subtyp(C, TEXT, TEXT text) = OK true
def $subtyp(C, VAR id targ*, val) = FAIL
    -- if PARAM = $find_typ(C, id)
def $subtyp(C, VAR id targ*, EXT json) = OK true
    -- if EXT = $find_typ(C, id)
def $subtyp(C, VAR id targ*, val) = $subtyp(C, typ_new, val)
    -- if DEF tparam* `-> (ALIAS typ) = $find_typ(C, id)
    -- if typ_new = $subst_typ(`{ (tparam `: targ)* }, typ)
def $subtyp(C, VAR id targ*, INJ mixop val) = OK $exists_(b*)
    -- if DEF tparam* `-> (VARIANT typcase*) = $find_typ(C, id)
    -- if theta = `{ (tparam `: targ)* }
    -- (if mixop_typcase typ_typcase = typcase)*
    -- (if b = ((mixop = mixop_typcase) /\ (OK true = $subtyps(C, ($subst_typ(theta, typ_typcase))*, val))))*
def $subtyp(C, VAR id targ*, val) = OK true
    -- if DEF tparam* `-> (VARIANT typcase*) = $find_typ(C, id)
    -- if ~$is_inj(val)
def $subtyp(C, VAR id targ*, val) = OK true
    -- if DEF tparam* `-> (STRUCT typfield*) = $find_typ(C, id)
def $subtyp(C, TUP typ*, TUP val*) = OK $forall_(b'*)
    -- if |typ*| = |val*|
    -- (if OK b' = $subtyp(C, typ, val))*
def $subtyp(C, TUP typ*, TUP val*) = FAIL
    -- if |typ*| = |val*|
    -- if $exists_((FAIL = $subtyp(C, typ, val))*)
def $subtyp(C, ITER typ QUEST, OPT val) = $subtyp(C, typ, val)
def $subtyp(C, ITER typ QUEST, OPT eps) = OK true 
def $subtyp(C, ITER typ STAR, LIST val*) = OK ($forall_(b*))
    -- if (OK b = $subtyp(C, typ, val))*
def $subtyp(C, ITER typ STAR, LIST val*) = FAIL
    -- if $exists_((FAIL = $subtyp(C, typ, val))*)
def $subtyp(C, typ, val) = OK false
    -- otherwise

;;

dec $access_path(ctx, val, path) : res<val>
def $access_path(C, val_b, ROOT) = OK val_b
def $access_path(C, val_b, IDX path exp_i) = OK (TEXT text[n_i])
    -- if OK (TEXT text) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
def $access_path(C, val_b, IDX path exp_i) = OK (val*[n_i])
    -- if OK (LIST val*) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
def $access_path(C, val_b, SLICE path exp_i exp_n) = OK (TEXT text[n_i : n_n])
    -- if OK (TEXT text) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)
def $access_path(C, val_b, SLICE path exp_i exp_n) = OK (LIST val*[n_i : n_n])
    -- if OK (LIST val*) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_i)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)
def $access_path(C, val_b, DOT path atom) = OK val
    -- if OK (STR valfield*) = $access_path(C, val_b, path)
    -- (if atom_field val_field = valfield)*
    -- if val = $find_map<atom, val>(`{ (atom_field `: val_field)* }, atom)
def $access_path(C, val, path) = FAIL
    -- otherwise

dec $update_path(ctx, val, path, val) : res<val>
def $update_path(C, val_b, ROOT, val_n) = OK val_n
def $update_path(C, val_b, IDX path exp_i, TEXT text_n) = $update_path(C, val_b, path, TEXT text[[n_target] = text_n])
    -- if OK (TEXT text) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_target)
    -- if |text_n| = 1
def $update_path(C, val_b, IDX path exp_i, val_n) = $update_path(C, val_b, path, (LIST val*[[n_target] = val_n]))
    -- if OK (LIST val*) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_target)
def $update_path(C, val_b, SLICE path exp_i exp_n, val_n) = $update_path(C, val_b, path, TEXT text[[n_l : n_n] = text'])
    -- if OK (TEXT text) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_l)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)
    -- if TEXT text' = val_n
    -- if |text'| = n_n
def $update_path(C, val_b, SLICE path exp_i exp_n, val_n) = $update_path(C, val_b, path, LIST val*[[n_l : n_n] = val'*])
    -- if OK (LIST val*) = $access_path(C, val_b, path)
    -- Eval_exp: C |- exp_i : OK (NAT n_l)
    -- Eval_exp: C |- exp_n : OK (NAT n_n)
    -- if LIST val'* = val_n
    -- if |val'*| = n_n
def $update_path(C, val_b, DOT path atom_path, val_n) = $update_path(C, val_b, path, STR valfield_new*)
    -- if OK (STR valfield*) = $access_path(C, val_b, path)
    -- (if atom_field val_field = valfield)*
    -- (if valfield_new = atom_field $ite<val>(atom_path = atom_field, val_n, val_field))*
def $update_path(C, val_b, path, val_n) = FAIL
    -- otherwise

;;

dec $assign_exp_aux1(ctx, vari*, val) : ctx
def $assign_exp_aux1(ctx, eps, val) = ctx
def $assign_exp_aux1(ctx, (id iter*) :: vari*, val) = $assign_exp_aux1(ctx', vari*, val)
    -- if ctx' = $add_val(ctx, (id (iter* ++ [ QUEST ])), val)

dec $assign_exp_aux2(ctx, vari*) : res<ctx>
def $assign_exp_aux2(ctx, eps) = OK ctx
def $assign_exp_aux2(ctx, (id iter*) :: vari*) = $assign_exp_aux2(ctx', vari*)
    -- if val = $find_val(ctx, id iter*)
    -- if ctx' = $add_val(ctx, id (iter* ++ [QUEST]), val)
def $assign_exp_aux2(ctx, vari*) = FAIL
    -- otherwise

dec $assign_exp_aux3(ctx, vari*, ctx*) : res<ctx> 
def $assign_exp_aux3(ctx_iter, eps, ctx*) = OK ctx_iter
def $assign_exp_aux3(ctx_iter, (id iter*) :: vari*, ctx*) = $assign_exp_aux3(ctx_iter', vari*, ctx*)
    -- (if val = $find_val(ctx, id iter*))*
    -- if ctx_iter' = $add_val(ctx_iter, id (iter* ++ [ STAR ]), LIST val*)
def $assign_exp_aux3(ctx_iter, vari*, ctx*) = FAIL
    -- otherwise

dec $assign_exps(ctx, exp*, val*) : res<ctx>
dec $assign_exp(ctx, exp, val) : res<ctx>
def $assign_exp(ctx, VAR id, val) = OK ($add_val(ctx, id eps, val))
def $assign_exp(ctx, TUP exp*, TUP val*) = $assign_exps(ctx, exp*, val*)
def $assign_exp(ctx, INJ mixop exp, INJ mixop' val) = $assign_exp(ctx, exp, val)
    -- if mixop = mixop'
def $assign_exp(ctx, STR expfield*, STR valfield*)  = $assign_exps(ctx, exp*, val*)
    -- (if atom exp = expfield)*
    -- (if atom val = valfield)*
def $assign_exp(ctx, OPT exp, OPT val) = $assign_exp(ctx, exp, val)
def $assign_exp(ctx, OPT eps, OPT eps) = OK ctx
def $assign_exp(ctx, LIST exp*, LIST val*) = $assign_exps(ctx, exp*, val*)
def $assign_exp(ctx, CONS exp_h exp_t, LIST (val_h :: val*)) = $assign_exp(ctx', exp_t, LIST val*)
    -- if OK ctx' = $assign_exp(ctx, exp_h, val_h)
def $assign_exp(ctx, ITER exp (QUEST vari*), OPT eps) = OK $assign_exp_aux1(ctx, vari*, OPT eps)
def $assign_exp(ctx, ITER exp (QUEST vari*), OPT val) = $assign_exp_aux2(ctx', vari*)
    -- if OK ctx' = $assign_exp(ctx, exp, val)
def $assign_exp(ctx, ITER exp (STAR vari*), LIST val*) = $assign_exp_aux3(ctx, vari*, ctx'*)
    -- (if OK ctx' = $assign_exp(ctx[ .LOCAL.VAL = $empty_map<vari, val>], exp, val))*
def $assign_exp(ctx, exp, val) = FAIL
    -- otherwise

def $assign_exps(ctx, eps, eps) = OK ctx
def $assign_exps(ctx, exp_cur :: exp*, val_cur :: val*) = $assign_exps(ctx', exp*, val*)
    -- if |exp*| = |val*|
    -- if OK ctx' = $assign_exp(ctx, exp_cur, val_cur)
def $assign_exps(ctx, exp*, val*) = FAIL
    -- otherwise

dec $assign_arg(ctx, ctx, arg, val) : res<ctx>
def $assign_arg(C_caller, C_callee, EXP exp, val) = $assign_exp(C_callee, exp, val)
def $assign_arg(C_caller, C_callee, FUN id, FUNC id') = OK ($add_func(C_callee, id, funcdef))
    -- if funcdef = $find_func(C_caller, id')
def $assign_arg(C_caller, C_callee, arg, val) = FAIL
    -- otherwise

dec $assign_args(ctx, ctx, arg*, val*) : res<ctx>
def $assign_args(C_caller, C_callee, eps, eps) = OK C_callee
def $assign_args(C_caller, C_callee, arg_cur :: arg*, val_cur :: val*) = $assign_args(C_caller, C_next, arg*, val*)
    -- if OK C_next = $assign_arg(C_caller, C_callee, arg_cur, val_cur)
def $assign_args(C_caller, C_callee, arg*, val*) = FAIL
    -- otherwise

;;

syntax matchres = ctx arg* prem* exp 

dec $match_clause(ctx, ctx, clause, val*) : res<matchres>
def $match_clause(C_caller, C_callee, clause, val*) = OK (C arg* prem* exp)
    -- if arg* `= exp `- prem* = clause
    -- if |arg*| = |val*|
    -- if OK C = $assign_args(C_caller, C_callee, arg*, val*)
def $match_clause(C_caller, C_callee, clause, val*) = FAIL
    -- otherwise


dec $do_backtrack_clause(ctx, ctx, val*, clause) : res<val> 
def $do_backtrack_clause(C, ctx_local, val*, clause) = OK val_output
    -- if OK (ctx'_local arg_input* prem* exp_output) = $match_clause(C, ctx_local, clause, val*)
    -- Eval_prems: ctx'_local |- prem* : OK ctx'
    -- Eval_exp : ctx'_local |- exp_output : OK val_output
def $do_backtrack_clause(C_1, C_2, val*, clause) = FAIL
    -- otherwise

dec $do_backtrack_func(ctx, ctx, val*, clause*) : res<val>
def $do_backtrack_func(ctx, ctx_local, val*, eps) = FAIL
def $do_backtrack_func(ctx, ctx_local, val*, clause_cur :: clause*) = OK val_res
    -- if OK val_res = $do_backtrack_clause(ctx, ctx_local, val*, clause_cur)
def $do_backtrack_func(ctx, ctx_local, val*, clause_cur :: clause*) = $do_backtrack_func(ctx, ctx_local, val*, clause*)
    -- if FAIL = $do_backtrack_clause(ctx, ctx_local, val*, clause_cur)

dec $concat_layer(layer, layer) : layer
def $concat_layer(layer_1, layer_2) = {TYP $extend_map<id, typdef>(layer_1.TYP, layer_2.TYP), REL $extend_map<id, reldef>(layer_1.REL, layer_2.REL), FUNC $extend_map<id, funcdef>(layer_1.FUNC, layer_2.FUNC), VAL $extend_map<vari, val>(layer_1.VAL, layer_2.VAL) }

dec $invoke_defined_func(ctx, id, tparam*, clause*, elsclause?, targ*, val*) : res<val>
def $invoke_defined_func(C, id, tparam*, clause*, elsclause?, targ*, val*) = $do_backtrack_func(C, ctx_local, val*, clause* ++ $opt_as_seq_<clause>(elsclause?))
    -- if |targ*| = |tparam*|
    -- if tdenv = `{ (tparam `: (DEF eps `-> (ALIAS targ)))* }
    -- if ctx_local = {GLOBAL {TYP $empty_map<id, typdef>, REL $empty_map<id, reldef>, FUNC $empty_map<id, funcdef>, VAL $empty_map<vari, val>}, LOCAL $concat_layer(C.LOCAL, {TYP tdenv, REL $empty_map<id, reldef>, FUNC $empty_map<id, funcdef>, VAL $empty_map<vari, val>}),}
def $invoke_defined_func(C, id, tparam*, clause*, elsclause?, targ*, val*) = FAIL
    -- otherwise

dec $invoke_func_aux(map<id, typdef>) : theta
def $invoke_func_aux(`{ eps }) = $empty_map<id, typ>
def $invoke_func_aux(`{ (id_head `: typdef_head) :: (id `: typdef)* }) = $add_map<id, typ>($invoke_func_aux(`{ (id `: typdef)* }), id_head, typ)
    -- if typdef_head = DEF eps `-> (ALIAS typ)
def $invoke_func_aux(`{ (id_head `: typdef_head) :: (id `: typdef)* }) = $invoke_func_aux(`{ (id `: typdef)* })
    -- if typdef_head = PARAM \/ typdef_head = EXT